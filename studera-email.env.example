# Copy these into your shell before starting server.py.
# Gmail requires a Google App Password, not the normal account password.
export STUDERA_SMTP_HOST="smtp.gmail.com"
export STUDERA_SMTP_PORT="587"
export STUDERA_SMTP_USER="studeraadmin@gmail.com"
export STUDERA_SMTP_FROM="studeraadmin@gmail.com"
export STUDERA_SMTP_PASSWORD="paste-gmail-app-password-here"
export STUDERA_SMTP_TLS="1"

# Initial site admin bootstrap for a fresh database.
# Use a real secret locally or in your deployment environment, never in GitHub.
export STUDERA_SECONDARY_SITE_ADMIN_EMAIL="studeraadmin@gmail.com"
export STUDERA_SECONDARY_SITE_ADMIN_PASSWORD="paste-studera-site-admin-password-here"
